---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Cart — Astro Shop">
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-semibold">Your cart</h1>

    <div id="cart-empty" class="mt-10 rounded-xl border border-dashed border-neutral-300 bg-white p-12 text-center hidden">
      <p class="text-neutral-600">Your cart is empty.</p>
      <a
        href="/products"
        class="mt-4 inline-flex items-center rounded-lg bg-indigo-600 text-white px-5 py-2.5 text-sm font-medium hover:bg-indigo-700 transition"
      >Browse the shop</a>
    </div>

    <div id="cart-filled" class="mt-8 hidden">
      <ul id="cart-items" class="divide-y divide-neutral-200 rounded-xl border border-neutral-200 bg-white"></ul>

      <div class="mt-6 flex flex-col sm:flex-row items-end sm:items-center sm:justify-between gap-4">
        <button
          id="clear-cart"
          type="button"
          class="text-sm text-neutral-500 hover:text-red-600"
        >Clear cart</button>

        <div class="text-right">
          <p class="text-sm text-neutral-500">Subtotal</p>
          <p id="cart-total" class="text-2xl font-semibold">$0.00</p>
          <a
            href="/checkout"
            class="mt-3 inline-flex items-center rounded-lg bg-indigo-600 text-white px-5 py-2.5 text-sm font-medium hover:bg-indigo-700 transition"
          >Checkout →</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { readCart, updateQty, removeFromCart, clearCart, cartTotal } from "../scripts/cart";
  import { formatPrice } from "../data/products";

  const emptyEl = document.getElementById("cart-empty")!;
  const filledEl = document.getElementById("cart-filled")!;
  const listEl = document.getElementById("cart-items")!;
  const totalEl = document.getElementById("cart-total")!;

  function render() {
    const items = readCart();
    if (items.length === 0) {
      emptyEl.classList.remove("hidden");
      filledEl.classList.add("hidden");
      return;
    }
    emptyEl.classList.add("hidden");
    filledEl.classList.remove("hidden");

    listEl.innerHTML = items
      .map(
        (i) => `
        <li class="flex items-center gap-4 p-4">
          <img src="${i.image}" alt="${i.name}" class="w-20 h-20 rounded-lg object-cover bg-neutral-100" />
          <div class="flex-1 min-w-0">
            <a href="/products/${i.slug}" class="font-medium hover:text-indigo-600">${i.name}</a>
            <p class="text-sm text-neutral-500">${formatPrice(i.price)} each</p>
          </div>
          <input
            type="number"
            min="0"
            max="99"
            value="${i.qty}"
            data-slug="${i.slug}"
            class="qty-input w-16 rounded-lg border border-neutral-300 px-2 py-1 text-sm"
          />
          <p class="w-20 text-right font-medium">${formatPrice(i.qty * i.price)}</p>
          <button
            type="button"
            data-slug="${i.slug}"
            class="remove-btn text-neutral-400 hover:text-red-600 text-sm"
            aria-label="Remove"
          >✕</button>
        </li>
      `,
      )
      .join("");

    totalEl.textContent = formatPrice(cartTotal(items));

    listEl.querySelectorAll<HTMLInputElement>(".qty-input").forEach((input) => {
      input.addEventListener("change", () => {
        updateQty(input.dataset.slug!, Number(input.value));
      });
    });

    listEl.querySelectorAll<HTMLButtonElement>(".remove-btn").forEach((btn) => {
      btn.addEventListener("click", () => removeFromCart(btn.dataset.slug!));
    });
  }

  document.getElementById("clear-cart")?.addEventListener("click", () => {
    if (confirm("Clear all items from your cart?")) clearCart();
  });

  render();
  window.addEventListener("cart:change", render);
  window.addEventListener("storage", render);
</script>
