---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Checkout — Astro Shop">
  <section class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-semibold">Checkout</h1>
    <p class="mt-2 text-neutral-600">
      This is a demo checkout. No payment is processed and no data is sent anywhere.
    </p>

    <div class="mt-8 grid grid-cols-1 md:grid-cols-[1fr_320px] gap-8">
      <form id="checkout-form" class="space-y-4 rounded-xl border border-neutral-200 bg-white p-6">
        <div>
          <label class="block text-sm font-medium" for="email">Email</label>
          <input id="email" name="email" type="email" required class="mt-1 w-full rounded-lg border border-neutral-300 px-3 py-2" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium" for="first">First name</label>
            <input id="first" name="first" required class="mt-1 w-full rounded-lg border border-neutral-300 px-3 py-2" />
          </div>
          <div>
            <label class="block text-sm font-medium" for="last">Last name</label>
            <input id="last" name="last" required class="mt-1 w-full rounded-lg border border-neutral-300 px-3 py-2" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium" for="address">Address</label>
          <input id="address" name="address" required class="mt-1 w-full rounded-lg border border-neutral-300 px-3 py-2" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium" for="city">City</label>
            <input id="city" name="city" required class="mt-1 w-full rounded-lg border border-neutral-300 px-3 py-2" />
          </div>
          <div>
            <label class="block text-sm font-medium" for="postal">Postal code</label>
            <input id="postal" name="postal" required class="mt-1 w-full rounded-lg border border-neutral-300 px-3 py-2" />
          </div>
        </div>
        <button
          type="submit"
          class="w-full rounded-lg bg-indigo-600 text-white px-5 py-3 text-sm font-medium hover:bg-indigo-700 transition"
        >Place order (demo)</button>
      </form>

      <aside class="rounded-xl border border-neutral-200 bg-white p-6 h-fit">
        <h2 class="font-semibold">Order summary</h2>
        <ul id="summary-items" class="mt-4 space-y-2 text-sm"></ul>
        <div class="mt-4 border-t border-neutral-200 pt-4 flex items-center justify-between">
          <span class="text-neutral-600">Total</span>
          <span id="summary-total" class="font-semibold">$0.00</span>
        </div>
      </aside>
    </div>

    <div id="success" class="hidden mt-8 rounded-xl border border-green-200 bg-green-50 p-6">
      <h2 class="font-semibold text-green-800">Order placed!</h2>
      <p class="mt-1 text-sm text-green-700">
        Thanks — this was a demo, so nothing was actually charged. Your cart has been emptied.
      </p>
      <a href="/products" class="mt-4 inline-flex items-center text-sm text-indigo-600 hover:underline">Continue shopping →</a>
    </div>
  </section>
</Layout>

<script>
  import { readCart, cartTotal, clearCart } from "../scripts/cart";
  import { formatPrice } from "../data/products";

  const itemsEl = document.getElementById("summary-items")!;
  const totalEl = document.getElementById("summary-total")!;
  const formEl = document.getElementById("checkout-form") as HTMLFormElement;
  const successEl = document.getElementById("success")!;
  const gridWrapper = formEl.parentElement!;

  function renderSummary() {
    const items = readCart();
    itemsEl.innerHTML = items.length
      ? items
          .map(
            (i) => `
            <li class="flex justify-between">
              <span class="truncate">${i.name} × ${i.qty}</span>
              <span>${formatPrice(i.qty * i.price)}</span>
            </li>
          `,
          )
          .join("")
      : '<li class="text-neutral-500">Your cart is empty.</li>';
    totalEl.textContent = formatPrice(cartTotal(items));
  }

  formEl.addEventListener("submit", (e) => {
    e.preventDefault();
    const items = readCart();
    if (items.length === 0) {
      alert("Your cart is empty.");
      return;
    }
    clearCart();
    gridWrapper.classList.add("hidden");
    successEl.classList.remove("hidden");
  });

  renderSummary();
  window.addEventListener("cart:change", renderSummary);
</script>
