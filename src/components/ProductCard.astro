---
import type { Product } from "../data/products";
import { formatPrice } from "../data/products";

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<a
  href={`/products/${product.slug}`}
  class="group block rounded-xl overflow-hidden bg-white border border-neutral-200 hover:border-indigo-400 hover:shadow-md transition"
>
  <div class="aspect-square overflow-hidden bg-neutral-100">
    <img
      src={product.image}
      alt={product.name}
      loading="lazy"
      class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
    />
  </div>
  <div class="p-4">
    <div class="flex items-start justify-between gap-2">
      <h3 class="font-medium">{product.name}</h3>
      <span class="shrink-0 font-semibold">{formatPrice(product.price, product.currency)}</span>
    </div>
    <p class="mt-1 text-sm text-neutral-500 line-clamp-1">{product.tagline}</p>
    {!product.inStock && (
      <span class="mt-3 inline-block text-xs bg-neutral-200 text-neutral-700 rounded px-2 py-0.5">
        Sold out
      </span>
    )}
  </div>
</a>
