    <p>&copy; {year} Astro Shop. Demo storefront.</p>
    <div class="flex gap-6">
      <a href="/products" class="hover:text-indigo-600">Shop</a>
      <a href="/cart" class="hover:text-indigo-600">Cart</a>
      <a href="https://astro.build" target="_blank" rel="noreferrer" class="hover:text-indigo-600">Built with Astro</a>
    </div>
  </div>
</footer>
