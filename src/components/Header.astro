---
---

<header class="border-b border-neutral-200 bg-white/80 backdrop-blur sticky top-0 z-40">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="font-semibold tracking-tight text-lg">
      <span class="text-indigo-600">◎</span> Astro Shop
    </a>
    <nav class="flex items-center gap-6 text-sm">
      <a href="/" class="hover:text-indigo-600">Home</a>
      <a href="/products" class="hover:text-indigo-600">Shop</a>
      <a href="/cart" class="relative hover:text-indigo-600 flex items-center gap-1">
        Cart
        <span
          id="cart-count-badge"
          class="inline-flex items-center justify-center min-w-5 h-5 px-1 text-xs font-medium rounded-full bg-indigo-600 text-white hidden"
        >0</span>
      </a>
    </nav>
  </div>
</header>

<script>
  import { readCart, cartCount } from "../scripts/cart";

  function refresh() {
    const badge = document.getElementById("cart-count-badge");
    if (!badge) return;
    const count = cartCount(readCart());
    badge.textContent = String(count);
    badge.classList.toggle("hidden", count === 0);
  }

  refresh();
  window.addEventListener("cart:change", refresh);
  window.addEventListener("storage", refresh);
</script>
